
@{
    ViewBag.Title = "Index";
}





<style>
    #coursecontainer {
        border: none;
        padding: 15px;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(20rem, auto));
        column-gap: 3rem; /* space between cards */
        justify-content:flex-start;
        overflow:hidden;
    }


    #coursemainheader {
        display: flex;
        align-items: center;
        justify-content: space-between;
        
    }

    #courseheader {
        text-align: center;

    }

    .card {
        box-shadow: 2px 4px 4px lightgray;
        border-radius: 10px;
        overflow: hidden;

    }
    .card-link {
        text-decoration: none; /* remove underline */
        color: inherit;
    }
    .card-link:hover {
            text-decoration: none; /* no underline on hover */
            color: inherit; /* don't turn blue */
    }

    .img-frame {
        width: 100%;
        height: 200px;
        display: flex;
        justify-content: center;
        align-items: center;
        border-radius: 10px;
        overflow: hidden;
    }

    .img-frame img {
            width: 100%;
            height: 100%;
            object-fit: contain;
    }
    #course{
            border:none;
            box-shadow:1px 6px 5px lightgray;
            padding:10px;
            margin-top:4rem;
     }
</style>

<div id="course">
    <div id="courseheader">
        <h3 style="color:gray;">ASP.NET MVC 5</h3>
    </div>
    <hr style="border: 1px solid lightgray;" />
    <div id="coursecontainer">

        <a href="@Url.Action("Playlistsection", "Courses", new { id = 5 })" class="card-link">
            <div class="card">
                <div class="img-frame">
                    <img src="~/Content/Images/download.jpg" alt="logo" class="card-img-top">
                </div>
                <div class="card-body">
                    <h5 class="card-title" style="margin-top:1rem; color:gray;">C# basics</h5>
                    <p class="card-text" style="color:gray; ">C# basics for beginners Playlist.</p>
                </div>
            </div>
        </a>



        <!-- more cards ... -->
    </div>
</div>


